{
  "name": "ipe-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "Onchain marketplace on Base for ipê.city merch — paid in $IPE, receipts as ERC-1155.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace shared run build && npm --workspace client run build && npm --workspace server run build",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vv",
    "contracts:deploy:sepolia": "cd contracts && forge script script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC --broadcast --verify",
    "db:push": "npm --workspace server run db:push",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
