# ─── Network ──────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
CHAIN_ID=84532

# ─── Contracts (filled after deploy) ──────────────────────
IPE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
IPE_MARKET_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Deploy ───────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
BASESCAN_API_KEY=

# ─── Server ───────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ipe_marketplace
PORT=3001
SHIPPING_ENCRYPTION_KEY=  # 32-byte hex for AES-256-GCM
INDEXER_POLL_INTERVAL_MS=15000
INDEXER_START_BLOCK=0

# Public URLs (used in webhook callbacks + email links)
PUBLIC_API_URL=http://localhost:3005
PUBLIC_APP_URL=http://localhost:5173

# ─── Mercado Pago (PIX) ──────────────────────────────────
# https://www.mercadopago.com.br/developers → Suas integrações
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── NOWPayments (crypto-gateway) ────────────────────────
# https://account.nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ─── Resend (email) ──────────────────────────────────────
# https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=IPE Store <orders@ipecity.example>
ADMIN_NOTIFICATION_EMAIL=

# ─── Optional ────────────────────────────────────────────
COINGECKO_IPE_ID=

# ─── Client ───────────────────────────────────────────────
VITE_PRIVY_APP_ID=
VITE_API_URL=http://localhost:3001
VITE_IPE_TOKEN_ADDRESS=
VITE_USDC_TOKEN_ADDRESS=
VITE_IPE_MARKET_ADDRESS=
VITE_CHAIN_ID=84532
